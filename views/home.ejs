<% title = 'Browse Talent Inventories' %>
<% const skills = typeof allSkills !== 'undefined' ? allSkills : [] %>
<%- include('partials/header') %>

<div class="max-w-5xl mx-auto px-4 py-12">
  <div class="text-center mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-3">Discover Talent</h1>
    <p class="text-gray-500 text-lg">Browse approved talent inventories from talented professionals.</p>
  </div>

  <% const levelCls = { '1': 'bg-gray-100 text-gray-500', '2': 'bg-blue-50 text-blue-600', '3': 'bg-indigo-50 text-indigo-700', '4': 'bg-violet-50 text-violet-700' } %>

  <% if (portfolios.length === 0) { %>
    <div class="text-center py-20 text-gray-400">
      <p class="text-lg">No talent inventories yet.</p>
      <a href="/submit" class="mt-4 inline-block text-indigo-600 hover:underline">Be the first to submit yours →</a>
    </div>
  <% } else { %>

    <!-- Filters -->
    <div class="mb-8 space-y-4">
      <input
        id="search"
        type="text"
        placeholder="Search by name or title..."
        class="w-full border border-gray-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
      />
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-xs text-gray-400 font-medium uppercase tracking-wide mr-1">Skills:</span>
        <button
          id="btn-all"
          onclick="toggleAll()"
          class="skill-btn text-xs px-3 py-1 rounded-full border border-indigo-300 bg-indigo-600 text-white transition-colors"
        >All</button>
        <% skills.forEach(skill => { %>
          <button
            onclick="toggleSkill('<%= skill %>', this)"
            class="skill-btn text-xs px-3 py-1 rounded-full border border-gray-200 bg-white text-gray-600 hover:border-indigo-300 hover:text-indigo-600 transition-colors"
            data-skill="<%= skill %>"
          ><%= skill %></button>
        <% }) %>
      </div>
    </div>

    <!-- Grid -->
    <div id="grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% portfolios.forEach(p => { %>
        <a
          href="/portfolio/<%= p.id %>"
          class="portfolio-card bg-white border border-gray-200 rounded-xl p-6 hover:shadow-md transition-shadow block"
          data-name="<%= p.name.toLowerCase() %>"
          data-title="<%= p.title.toLowerCase() %>"
          data-skills="<%= p.skills.split(',').map(s => s.trim().split(':')[0].trim().toLowerCase()).join(',') %>"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-lg">
              <%= p.name[0].toUpperCase() %>
            </div>
            <div>
              <p class="font-semibold text-gray-900"><%= p.name %></p>
              <p class="text-sm text-gray-500"><%= p.title %></p>
            </div>
          </div>
          <p class="text-sm text-gray-600 line-clamp-3"><%= p.bio %></p>
          <div class="mt-4 flex flex-wrap gap-1">
            <% p.skills.split(',').slice(0, 3).forEach(function(skill) { %>
              <% const parts = skill.trim().split(':') %>
              <% const sName = parts[0].trim() %>
              <% const sLevel = parts[1] ? parts[1].trim() : null %>
              <span class="text-xs px-2 py-0.5 rounded-full <%= sLevel && levelCls[sLevel] ? levelCls[sLevel] : 'bg-indigo-50 text-indigo-700' %>"><%= sName %></span>
            <% }) %>
          </div>
        </a>
      <% }) %>
    </div>

    <p id="empty-msg" class="hidden text-center py-16 text-gray-400">No talent inventories match your filter.</p>

  <% } %>
</div>

<script>
  const activeSkills = new Set()

  function toggleSkill(skill, btn) {
    if (activeSkills.has(skill)) {
      activeSkills.delete(skill)
      btn.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-300')
      btn.classList.add('bg-white', 'text-gray-600', 'border-gray-200')
    } else {
      activeSkills.add(skill)
      btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-300')
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200')
    }
    syncAllButton()
    applyFilters()
  }

  function toggleAll() {
    activeSkills.clear()
    document.querySelectorAll('.skill-btn[data-skill]').forEach(b => {
      b.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-300')
      b.classList.add('bg-white', 'text-gray-600', 'border-gray-200')
    })
    syncAllButton()
    applyFilters()
  }

  function syncAllButton() {
    const allBtn = document.getElementById('btn-all')
    const isAll = activeSkills.size === 0
    allBtn.classList.toggle('bg-indigo-600', isAll)
    allBtn.classList.toggle('text-white', isAll)
    allBtn.classList.toggle('border-indigo-300', isAll)
    allBtn.classList.toggle('bg-white', !isAll)
    allBtn.classList.toggle('text-gray-600', !isAll)
    allBtn.classList.toggle('border-gray-200', !isAll)
  }

  document.getElementById('search')?.addEventListener('input', applyFilters)

  function applyFilters() {
    const query = document.getElementById('search').value.toLowerCase().trim()
    const cards = document.querySelectorAll('.portfolio-card')
    let visible = 0
    cards.forEach(card => {
      const matchesSearch = !query ||
        card.dataset.name.includes(query) ||
        card.dataset.title.includes(query)
      const cardSkills = card.dataset.skills.split(',').map(s => s.trim())
      const matchesSkill = activeSkills.size === 0 ||
        [...activeSkills].every(s => cardSkills.includes(s.toLowerCase()))
      const show = matchesSearch && matchesSkill
      card.style.display = show ? '' : 'none'
      if (show) visible++
    })
    document.getElementById('empty-msg').classList.toggle('hidden', visible > 0)
  }
</script>

<%- include('partials/footer') %>
