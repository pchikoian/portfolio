<% title = portfolio.name %>
<%- include('partials/header') %>

<div class="max-w-3xl mx-auto px-4 py-12">
  <% if (submitted) { %>
    <div class="mb-6 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm">
      Your talent inventory has been submitted and is pending review. It will appear publicly once approved.
    </div>
  <% } %>
  <% if (portfolio.status === 'pending' && !submitted) { %>
    <div class="mb-6 bg-yellow-50 border border-yellow-200 text-yellow-800 rounded-lg px-4 py-3 text-sm">
      This talent inventory is pending review and not yet publicly visible.
    </div>
  <% } %>
  <% if (portfolio.status === 'rejected') { %>
    <div class="mb-6 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm">
      This talent inventory was not approved.
    </div>
  <% } %>

  <div class="bg-white border border-gray-200 rounded-xl p-8">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-700 font-bold text-2xl">
        <%= portfolio.name[0].toUpperCase() %>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= portfolio.name %></h1>
        <p class="text-gray-500"><%= portfolio.title %></p>
      </div>
    </div>

    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">About</h2>
      <p class="text-gray-700 leading-relaxed"><%= portfolio.bio %></p>
    </section>

    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Skills</h2>
      <%
        const levelMeta = { '1': { label: 'Awareness', cls: 'bg-gray-100 text-gray-500' }, '2': { label: 'Practitioner', cls: 'bg-blue-50 text-blue-600' }, '3': { label: 'Proficient', cls: 'bg-indigo-50 text-indigo-700' }, '4': { label: 'Expert', cls: 'bg-violet-50 text-violet-700' } }
      %>
      <div class="flex flex-wrap gap-2">
        <% portfolio.skills.split(',').forEach(entry => { %>
          <% const parts = entry.trim().split(':'); const sName = parts[0].trim(); const sLevel = parts[1] ? parts[1].trim() : null %>
          <span class="flex items-center gap-1.5 bg-indigo-50 text-indigo-700 px-3 py-1 rounded-full text-sm">
            <%= sName %>
            <% if (sLevel && levelMeta[sLevel]) { %>
              <span class="text-xs px-1.5 py-0.5 rounded-full font-medium <%= levelMeta[sLevel].cls %>"><%= levelMeta[sLevel].label %></span>
            <% } %>
          </span>
        <% }) %>
      </div>
    </section>

    <% if (portfolio.interests) { %>
    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Interests</h2>
      <div class="flex flex-wrap gap-2">
        <% portfolio.interests.split(',').forEach(item => { %>
          <span class="bg-amber-50 text-amber-700 px-3 py-1 rounded-full text-sm"><%= item.trim() %></span>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (portfolio.certifications) { %>
    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Certifications</h2>
      <div class="flex flex-wrap gap-2">
        <% portfolio.certifications.split(',').forEach(cert => { %>
          <span class="bg-green-50 text-green-700 px-3 py-1 rounded-full text-sm">🎓 <%= cert.trim() %></span>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (portfolio.products) { %>
    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Products</h2>
      <div class="flex flex-col gap-2">
        <% portfolio.products.split(';').forEach((product, i) => { %>
          <% if (product.trim()) { %>
            <div class="flex items-center gap-3 bg-violet-50 border border-violet-100 rounded-lg px-4 py-2 text-sm text-violet-800">
              <span class="font-semibold text-violet-400"><%= i + 1 %>.</span>
              <%= product.trim() %>
            </div>
          <% } %>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (portfolio.projects) { %>
    <section class="mb-6">
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Projects</h2>
      <ul class="space-y-2">
        <% portfolio.projects.split(';').forEach(project => { %>
          <% if (project.trim()) { %>
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <span class="mt-1 text-indigo-400">▸</span>
              <%= project.trim() %>
            </li>
          <% } %>
        <% }) %>
      </ul>
    </section>
    <% } %>

    <section>
      <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-2">Contact & Links</h2>
      <ul class="space-y-2 text-sm">
        <li><span class="text-gray-500">Email:</span>
          <a href="mailto:<%= portfolio.email %>" class="text-indigo-600 hover:underline ml-1"><%= portfolio.email %></a>
        </li>
        <% if (portfolio.github) { %>
          <li><span class="text-gray-500">GitHub:</span>
            <a href="<%= portfolio.github %>" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline ml-1"><%= portfolio.github %></a>
          </li>
        <% } %>
        <% if (portfolio.linkedin) { %>
          <li><span class="text-gray-500">LinkedIn:</span>
            <a href="<%= portfolio.linkedin %>" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline ml-1"><%= portfolio.linkedin %></a>
          </li>
        <% } %>
        <% if (portfolio.website) { %>
          <li><span class="text-gray-500">Website:</span>
            <a href="<%= portfolio.website %>" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:underline ml-1"><%= portfolio.website %></a>
          </li>
        <% } %>
      </ul>
    </section>
  </div>

  <div class="mt-6">
    <a href="/" class="text-sm text-gray-500 hover:text-gray-700">← Back to all talent inventories</a>
  </div>
</div>

<%- include('partials/footer') %>
